<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Laser Calculator PRO</title>
    <script src="https://unpkg.com/dxf-parser@1.1.2/dist/dxf-parser.min.js"></script>
    <style>
        body { background: #000; color: #fff; font-family: sans-serif; margin: 0; overflow: hidden; touch-action: none; height: 100vh; display: flex; flex-direction: column; }
        .ui-top { padding: 10px; background: #1a1a1a; border-bottom: 1px solid #333; z-index: 10; }
        #canvas-container { flex-grow: 1; background: #000; position: relative; }
        canvas { width: 100%; height: 100%; display: block; }
        .ui-bottom { background: #1a1a1a; padding: 15px; border-radius: 20px 20px 0 0; z-index: 10; box-shadow: 0 -5px 15px rgba(0,0,0,0.5); }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        input { background: #222; border: 1px solid #444; color: #00ff41; padding: 12px; border-radius: 8px; font-size: 16px; width: 85%; }
        label { font-size: 11px; color: #888; margin-bottom: 4px; display: block; }
        .btn-file { background: #00ff41; color: #000; padding: 12px; text-align: center; border-radius: 8px; font-weight: bold; cursor: pointer; display: block; margin-bottom: 10px; }
        .res-bar { grid-column: span 2; display: flex; justify-content: space-between; background: #000; padding: 10px; border-radius: 10px; margin: 5px 0; border: 1px solid #333; }
        .total { font-size: 28px; color: #00ff41; text-align: center; font-weight: bold; margin-top: 10px; }
    </style>
</head>
<body>

<div class="ui-top"><strong>LASER CALC</strong></div>

<div id="canvas-container">
    <canvas id="mc"></canvas>
</div>

<div class="ui-bottom">
    <label class="btn-file" for="f">📂 ЗАВАНТАЖИТИ DXF</label>
    <input type="file" id="f" accept=".dxf" style="display:none">

    <div class="grid">
        <div class="field">
            <label>Бажана ВИСОТА (мм)</label>
            <input type="number" id="th" placeholder="Авто">
        </div>
        <div class="field">
            <label>Врізки (шт)</label>
            <input type="number" id="p" value="0">
        </div>
        <div class="res-bar">
            <div style="text-align:center"><small>Ш x В</small><br><span id="out-d">-</span></div>
            <div style="text-align:center"><small>Різ (м)</small><br><span id="out-l">0</span></div>
            <div style="text-align:center"><small>Врізки</small><br><span id="out-p">0</span></div>
        </div>
    </div>
    <div class="total"><span id="total">0</span> грн</div>
</div>

<script>
    const canvas = document.getElementById('mc');
    const ctx = canvas.getContext('2d');
    let dxfData = null, stats = { l: 0, p: 0, w: 0, h: 0, minX: 0, minY: 0 };
    let cam = { x: 0, y: 0, z: 1 }, lastT = [];

    document.getElementById('f').onchange = function(e) {
        const r = new FileReader();
        r.onload = function(ev) {
            try {
                const p = new DxfParser();
                dxfData = p.parseSync(ev.target.result);
                analyze();
                resetCam();
                calc();
                render();
            } catch (err) { alert("Помилка DXF"); }
        };
        r.readAsText(e.target.files[0]);
    };

    function analyze() {
        let l = 0, xmin = Infinity, xmax = -Infinity, ymin = Infinity, ymax = -Infinity;
        dxfData.entities.forEach(e => {
            if(e.type === 'LINE' || e.type === 'LWPOLYLINE') {
                const v = e.vertices;
                for(let i=0; i<v.length-1; i++) {
                    l += Math.hypot(v[i+1].x - v[i].x, v[i+1].y - v[i].y);
                    [v[i], v[i+1]].forEach(pt => {
                        xmin = Math.min(xmin, pt.x); xmax = Math.max(xmax, pt.x);
                        ymin = Math.min(ymin, pt.y); ymax = Math.max(ymax, pt.y);
                    });
                }
            }
        });
        stats = { l, p: dxfData.entities.length, w: xmax-xmin, h: ymax-ymin, minX: xmin, minY: ymin };
        document.getElementById('th').value = Math.round(stats.h);
    }

    function resetCam() {
        canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight;
        cam.z = Math.min(canvas.width/stats.w, canvas.height/stats.h) * 0.8;
        cam.x = canvas.width/2 - (stats.minX + stats.w/2) * cam.z;
        cam.y = canvas.height/2 + (stats.minY + stats.h/2) * cam.z;
    }

    function render() {
        if(!dxfData) return;
        ctx.setTransform(1,0,0,1,0,0);
        ctx.clearRect(0,0,canvas.width,canvas.height);
        ctx.translate(cam.x, cam.y);
        ctx.scale(cam.z, -cam.z);
        ctx.strokeStyle = '#00ff41'; ctx.lineWidth = 1/cam.z;
        dxfData.entities.forEach(e => {
            if(e.type === 'LINE' || e.type === 'LWPOLYLINE') {
                ctx.beginPath(); ctx.moveTo(e.vertices[0].x, e.vertices[0].y);
                for(let i=1; i<e.vertices.length; i++) ctx.lineTo(e.vertices[i].x, e.vertices[i].y);
                ctx.stroke();
            }
        });
        requestAnimationFrame(render);
    }

    function calc() {
        const th = parseFloat(document.getElementById('th').value) || stats.h;
        const s = th / stats.h;
        const curL = ((stats.l * s) / 1000).toFixed(2);
        const p = stats.p + (parseInt(document.getElementById('p').value) || 0);
        document.getElementById('out-d').innerText = Math.round(stats.w*s) + 'x' + Math.round(th);
        document.getElementById('out-l').innerText = curL;
        document.getElementById('out-p').innerText = p;
        document.getElementById('total').innerText = Math.round(curL * 25 + p * 2);
    }

    canvas.addEventListener('touchstart', e => { lastT = e.touches; }, {passive: false});
    canvas.addEventListener('touchmove', e => {
        e.preventDefault();
        const t = e.touches;
        if(t.length === 1 && lastT.length === 1) {
            cam.x += t[0].pageX - lastT[0].pageX; cam.y += t[0].pageY - lastT[0].pageY;
        } else if(t.length === 2 && lastT.length === 2) {
            const d1 = Math.hypot(lastT[0].pageX-lastT[1].pageX, lastT[0].pageY-lastT[1].pageY);
            const d2 = Math.hypot(t[0].pageX-t[1].pageX, t[0].pageY-t[1].pageY);
            const f = d2/d1; cam.z *= f;
            const mx = (t[0].pageX+t[1].pageX)/2, my = (t[0].pageY+t[1].pageY)/2;
            cam.x = mx - (mx - cam.x) * f; cam.y = my - (my - cam.y) * f;
        }
        lastT = t;
    }, {passive: false});

    ['th', 'p'].forEach(id => document.getElementById(id).oninput = calc);
</script>
</body>
</html>
