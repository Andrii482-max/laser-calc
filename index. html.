<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laser Calc</title>
    <script src="https://cdn.jsdelivr.net/npm/dxf-parser@1.1.2/dist/dxf-parser.min.js"></script>
    <style>
        body { background: #121212; color: white; font-family: sans-serif; text-align: center; margin: 0; padding: 20px; }
        .box { background: #1e1e1e; border: 1px solid #444; padding: 20px; border-radius: 15px; }
        .btn { background: #00ff41; color: black; padding: 15px; display: block; border-radius: 10px; font-weight: bold; margin-bottom: 20px; cursor: pointer; }
        input { width: 100%; background: #333; border: 1px solid #555; color: white; padding: 10px; margin: 10px 0; border-radius: 5px; }
    </style>
</head>
<body>

<div class="box">
    <h2>ЛАЗЕРНИЙ КАЛЬКУЛЯТОР</h2>
    <label class="btn" for="dxf">📁 ЗАВАНТАЖИТИ DXF</label>
    <input type="file" id="dxf" style="display:none">
    
    <label>Ціна за метр:</label>
    <input type="number" id="price" value="25">
    
    <div id="res" style="margin-top:20px; font-size: 20px; color: #00ff41;">
        Очікування файлу...
    </div>
</div>

<script>
    document.getElementById('dxf').onchange = function(e) {
        const reader = new FileReader();
        reader.onload = function(res) {
            try {
                const parser = new DxfParser();
                const dxf = parser.parseSync(res.target.result);
                let len = 0;
                dxf.entities.forEach(ent => {
                    if(ent.type === 'LINE') {
                        len += Math.hypot(ent.vertices[1].x - ent.vertices[0].x, ent.vertices[1].y - ent.vertices[0].y);
                    }
                });
                const totalLen = (len / 1000).toFixed(2);
                const price = document.getElementById('price').value;
                document.getElementById('res').innerHTML = `Різ: ${totalLen} м <br> Сума: ${Math.round(totalLen * price)} грн`;
            } catch (err) { alert("Помилка файлу"); }
        };
        reader.readAsText(e.target.files[0]);
    };
</script>

</body>
</html>
